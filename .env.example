# ── Reddit API ────────────────────────────────────────────────────────────────
# Get these from https://www.reddit.com/prefs/apps (create a "script" type app)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=MemestockRadar/1.0 by YourUsername

# Optional: cache refresh interval in seconds (default 300 = 5 min)
CACHE_TTL=300

# Optional: how many posts to fetch per subreddit (default 50, max 100)
POST_LIMIT=50

# ── News API ──────────────────────────────────────────────────────────────────
# Finnhub (recommended — free tier covers 60 req/min): https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# ── Email (Gmail SMTP) ────────────────────────────────────────────────────────
# Use a Gmail App Password (not your main password):
# https://myaccount.google.com/apppasswords
GMAIL_SENDER=your_email@gmail.com
GMAIL_RECIPIENT=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# ── Claude API (optional) ─────────────────────────────────────────────────────
# Get from https://console.anthropic.com/settings/keys
# If absent, the agent still runs — trade theses fall back to assembled rationale strings.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Flask / Docker ────────────────────────────────────────────────────────────
# Set to 0.0.0.0 when running in Docker so the container is reachable
FLASK_HOST=127.0.0.1
PORT=5050
